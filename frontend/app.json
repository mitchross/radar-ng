{
  "expo": {
    "name": "radar-ng",
    "slug": "radar-ng",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "radarng",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "bundleIdentifier": "com.vanillax.radar-ng",
      "buildNumber": "2",
      "appleTeamId": "FVU6RGL532",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "radar-ng uses your location to show local weather radar and forecasts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#081A24",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.vanillax.radarng",
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#081A24",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "26.0"
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "./plugins/withXcode27PodDeploymentFloor",
      "./plugins/withCarPlayScene",
      "./plugins/withScriptSandboxOff",
      "@bacons/apple-targets",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/newsreader/400Regular/Newsreader_400Regular.ttf",
            "node_modules/@expo-google-fonts/newsreader/400Regular_Italic/Newsreader_400Regular_Italic.ttf",
            "node_modules/@expo-google-fonts/newsreader/500Medium/Newsreader_500Medium.ttf",
            "node_modules/@expo-google-fonts/spline-sans/400Regular/SplineSans_400Regular.ttf",
            "node_modules/@expo-google-fonts/spline-sans/500Medium/SplineSans_500Medium.ttf",
            "node_modules/@expo-google-fonts/spline-sans/600SemiBold/SplineSans_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/spline-sans/700Bold/SplineSans_700Bold.ttf"
          ]
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-localization",
      "expo-secure-store",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
