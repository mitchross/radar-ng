# radar-ng docker-compose knobs. Copy to `.env` next to docker-compose.yml
# and edit — every value here is optional except where noted; defaults live
# in docker-compose.yml and match these.

# --- Ports (host side) -------------------------------------------------------
# Host port for the public API / tiles (container :8080).
TILE_SERVER_PORT=8080
# Host port for Temporal gRPC (for `temporal --address localhost:7233 ...`).
TEMPORAL_PORT=7233
# Host port for the optional Temporal Web UI (`--profile ui`).
TEMPORAL_UI_PORT=8233

# --- Temporal ------------------------------------------------------------------
# Temporal frontend address as seen from inside the compose network; point at
# an external cluster instead to skip the bundled temporal/temporal-postgres.
TEMPORAL_ADDRESS=temporal:7233
# Temporal namespace used by workers and the API.
TEMPORAL_NAMESPACE=default
# Set to 1 to stop the worker from (re)seeding Temporal Schedules on boot.
SKIP_SCHEDULE_SEED=0

# --- Upstream identification (SET THIS) ---------------------------------------
# api.weather.gov requires a contact in the User-Agent; use your own email.
NWS_USER_AGENT=(radar-ng, you@example.com)
# NWS active-alerts feed polled every 5 min.
NWS_ALERTS_URL=https://api.weather.gov/alerts/active?status=actual
# NHC tropical cyclone feed polled hourly.
TROPICAL_FEED_URL=https://www.nhc.noaa.gov/CurrentStorms.json

# --- Basemap bootstrap (SET THIS, then `docker compose run --rm basemap-bootstrap`)
# Protomaps daily planet build. Date-stamped (YYYYMMDD), ~6-day retention,
# no `latest` alias — pick a recent date from https://build.protomaps.com/.
BASEMAP_PMTILES_URL=https://build.protomaps.com/20260630.pmtiles
# Extract bbox minLon,minLat,maxLon,maxLat (default = CONUS; ~1-2 GB).
BASEMAP_BBOX=-125,24,-66,50

# --- Ingest / render tunables ---------------------------------------------------
# Color palettes to render; each needs backend/shared/palettes/<name>.json.
PALETTES=classic,muted,vivid
# Max MRMS frames back-filled per 2-min cycle (prod: 3; raise to catch up faster).
BACKLOG_PER_CYCLE=2
# Max Temporal activities running concurrently in the worker (prod: 4).
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=2
# Concurrent activity task polls (prod: 2).
TEMPORAL_MAX_CONCURRENT_ACTIVITY_TASK_POLLS=1
# Parallel palette-render processes per MRMS frame.
MRMS_RENDER_WORKERS=2
# HRRR forecast hours rendered every model run.
FORECAST_HOURS=18
# Extended HRRR forecast hours (sub-hourly layers).
EXTENDED_FORECAST_HOURS=48

# --- Nowcast (pysteps S-PROG) -----------------------------------------------
# Minutes of extrapolated nowcast to produce.
NOWCAST_HORIZON_MIN=60
# Minutes between nowcast frames.
NOWCAST_STEP_MIN=5
# Number of recent MRMS frames fed into the motion field.
NOWCAST_INPUT_FRAMES=4

# --- Storm watch ----------------------------------------------------------------
# Radius (km) around a watched location that triggers storm alerts.
WATCH_RADIUS_KM=20
# dBZ increase over previous frame considered "intensifying".
INTENSIFY_DBZ_DELTA=10
# dBZ decrease considered "dissipating".
DISSIPATE_DBZ_DELTA=10
# dBZ at/above which hail is flagged.
HAIL_DBZ_THRESHOLD=60
# 1 = never touch APNS/FCM (default); needs key files wired before enabling.
PUSH_DISABLED=1

# --- Lightning ------------------------------------------------------------------
# Minutes of Blitzortung strikes kept in the rolling buffer.
LIGHTNING_RETENTION_MIN=15
# Seconds between buffer flushes to state dir.
LIGHTNING_FLUSH_S=2.0

# --- Tile-server API -------------------------------------------------------------
# Forecast upstream; default is the bundled self-hosted open-meteo service.
OPEN_METEO_BASE=http://open-meteo:8080/v1/forecast
# Radar age (s) past which /api/health reports degraded.
MRMS_MAX_AGE_S=600
# In-process forecast response cache TTL (s).
FORECAST_TTL_S=300
