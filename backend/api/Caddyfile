:8080 {
    # Radar/forecast tiles.
    # Observed MRMS frames (radar, radar-composite) are written exactly once
    # per timestamp dir, so they can be cached hard — this is what lets the
    # app's playback loop replay past frames without re-fetching every tile.
    # Forecast products also publish immutable paths (HRRR includes run_id),
    # so every advertised tile can share the same cache contract.
    handle /tiles/* {
        root * /data
        file_server {
            precompressed gzip
        }
        header Cache-Control "public, max-age=86400, immutable"
        header Access-Control-Allow-Origin "*"
    }

    # Protomaps basemap style JSONs (shipped in image at /srv/basemap/styles/)
    handle /basemap/styles/* {
        uri strip_prefix /basemap
        root * /srv/basemap
        file_server
        header Cache-Control "public, max-age=3600"
        header Access-Control-Allow-Origin "*"
    }

    # Protomaps PMTiles tile server. go-pmtiles exposes tiles at
    # /{archive}/{z}/{x}/{y}.mvt — our archive is basemap.pmtiles so
    # archive = "basemap". Client requests /basemap/tiles/{z}/{x}/{y}.mvt,
    # which we rewrite to /basemap/{z}/{x}/{y}.mvt internally.
    handle_path /basemap/tiles/* {
        rewrite * /basemap{uri}
        reverse_proxy basemap:8081
        header Cache-Control "public, max-age=86400"
        header Access-Control-Allow-Origin "*"
    }

    # API endpoints (FastAPI)
    handle /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    # Workflow endpoints (FastAPI) — push tokens + storm watches live under
    # /v1 (routes_workflows.py mounts APIRouter(prefix="/v1")). Without this
    # handle, Caddy answers /v1/* itself with an empty 200 and FastAPI never
    # sees the request.
    handle /v1/* {
        reverse_proxy 127.0.0.1:8000
    }

    # Errors must never carry a cacheable Cache-Control. The header
    # directives above run BEFORE file_server, so a tile 404 would otherwise
    # ship with max-age=86400+immutable and the client (or any cache on the
    # path) pins the miss — an observed frame requested slightly early would
    # never render on that client for a day. Overriding in the error chain
    # (rather than a `file` matcher on the header directives) costs no extra
    # stat per request and also covers the stat-then-open race while a frame
    # is being atomically replaced.
    handle_errors {
        header Cache-Control "no-store"
        respond "{err.status_code} {err.status_text}" {err.status_code}
    }

    log {
        output stdout
        format console
    }
}
