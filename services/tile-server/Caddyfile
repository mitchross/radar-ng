:8080 {
    # Radar/forecast tiles
    handle /tiles/* {
        root * /data
        file_server {
            precompressed gzip
        }
        header Cache-Control "public, max-age=120"
        header Access-Control-Allow-Origin "*"
    }

    # Protomaps basemap — PMTiles tile server
    handle /basemap/tiles/* {
        uri strip_prefix /basemap/tiles
        reverse_proxy basemap:8081
        header Cache-Control "public, max-age=86400"
        header Access-Control-Allow-Origin "*"
    }

    # Protomaps basemap style JSONs (shipped in image)
    handle /basemap/styles/* {
        uri strip_prefix /basemap
        root * /srv/basemap
        file_server
        header Cache-Control "public, max-age=3600"
        header Access-Control-Allow-Origin "*"
    }

    # API endpoints (FastAPI)
    handle /api/* {
        reverse_proxy localhost:8000
        header Access-Control-Allow-Origin "*"
    }

    log {
        output stdout
        format console
    }
}
