{
  "version": 8,
  "name": "StormScope Light (Positron)",
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "protomaps": {
      "type": "vector",
      "tiles": ["/basemap/tiles/{z}/{x}/{y}.mvt"],
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "<a href=\"https://protomaps.com\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f2f1ea" }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": { "fill-color": "#e9e8e2" }
    },
    {
      "id": "landuse_park",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "park", "forest", "nature_reserve", "cemetery", "wood"],
      "paint": { "fill-color": "#d4e3c3" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": { "fill-color": "#b8d8e6" }
    },
    {
      "id": "roads_minor",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "minor_road"],
      "minzoom": 11,
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "stops": [[11, 0.5], [14, 1.5], [18, 6]] }
      }
    },
    {
      "id": "roads_major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "medium_road"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "stops": [[6, 0.5], [12, 2], [18, 10]] }
      }
    },
    {
      "id": "roads_highway",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "highway"],
      "paint": {
        "line-color": "#ffd68a",
        "line-width": { "stops": [[4, 0.5], [8, 2], [16, 12]] }
      }
    },
    {
      "id": "boundaries_country",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["<=", "kind_detail", 2],
      "paint": { "line-color": "#8f8f8f", "line-width": 1 }
    },
    {
      "id": "boundaries_state",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["==", "kind_detail", 4],
      "paint": { "line-color": "#bfbfbf", "line-width": 0.75, "line-dasharray": [2, 2] }
    },
    {
      "id": "places_city",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "kind", "city", "locality"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": { "stops": [[4, 10], [10, 14]] }
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
